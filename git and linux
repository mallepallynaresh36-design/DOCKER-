    <!-- DECLARATIVE PIPELINE -->
    <div class="section">
      <div class="section-title st-jenkins">03 — Declarative pipeline — full reference</div>
      <div class="card-full">
        <div class="card-title"><span class="dot dot-pink"></span>Complete Jenkinsfile with all blocks — memorise this skeleton</div>
        <div class="code-block">
<span class="kw-jenkins">pipeline</span> {
    <span class="kw-jenkins">agent</span> any                         <span class="cmt">// run on any available agent</span>
    <span class="cmt">// agent { label 'linux-node' }   // target specific node by label</span>
    <span class="cmt">// agent none                      // no global agent, define per-stage</span>

    <span class="kw-jenkins">environment</span> {
        APP_ENV   = <span class="str">'production'</span>
        REGISTRY  = <span class="str">'docker.io/myorg'</span>
        IMAGE_TAG = <span class="str">"${BUILD_NUMBER}"</span>   <span class="cmt">// built-in Jenkins env var</span>
    }

    <span class="kw-jenkins">options</span> {
        timeout(time: 30, unit: <span class="str">'MINUTES'</span>)  <span class="cmt">// abort if pipeline takes too long</span>
        buildDiscarder(logRotator(numToKeepStr: <span class="str">'10'</span>))
        disableConcurrentBuilds()              <span class="cmt">// no parallel runs of same job</span>
    }

    <span class="kw-jenkins">parameters</span> {
        string(name: <span class="str">'BRANCH'</span>, defaultValue: <span class="str">'main'</span>, description: <span class="str">'Branch to deploy'</span>)
        booleanParam(name: <span class="str">'RUN_TESTS'</span>, defaultValue: true)
    }

    <span class="kw-jenkins">triggers</span> {
        pollSCM(<span class="str">'H/5 * * * *'</span>)    <span class="cmt">// poll every 5 mins (use webhook instead)</span>
        cron(<span class="str">'0 2 * * *'</span>)         <span class="cmt">// scheduled: 2am daily</span>
    }

    <span class="kw-jenkins">stages</span> {

        <span class="kw-jenkins">stage</span>(<span class="str">'Checkout'</span>) {
            <span class="kw-jenkins">steps</span> {
                git branch: <span class="str">'main'</span>, url: <span class="str">'https://github.com/org/repo.git'</span>
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Build'</span>) {
            <span class="kw-jenkins">steps</span> {
                sh <span class="str">'mvn clean package -DskipTests'</span>
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Test'</span>) {
            <span class="kw-jenkins">when</span> { expression { params.RUN_TESTS == true } }
            <span class="kw-jenkins">steps</span> {
                sh <span class="str">'mvn test'</span>
            }
            post {
                always { junit <span class="str">'**/target/surefire-reports/*.xml'</span> }
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Parallel — Lint & Security Scan'</span>) {
            <span class="kw-jenkins">parallel</span> {
                <span class="kw-jenkins">stage</span>(<span class="str">'Lint'</span>)          { steps { sh <span class="str">'npm run lint'</span> } }
                <span class="kw-jenkins">stage</span>(<span class="str">'Security scan'</span>) { steps { sh <span class="str">'trivy fs .'</span> } }
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Docker Build & Push'</span>) {
            <span class="kw-jenkins">steps</span> {
                <span class="kw-jenkins">withCredentials</span>([usernamePassword(
                    credentialsId: <span class="str">'docker-hub-creds'</span>,
                    usernameVariable: <span class="str">'DOCKER_USER'</span>,
                    passwordVariable: <span class="str">'DOCKER_PASS'</span>
                )]) {
                    sh <span class="str">"""
                        docker build -t ${REGISTRY}/myapp:${IMAGE_TAG} .
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        docker push ${REGISTRY}/myapp:${IMAGE_TAG}
                    """</span>
                }
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Deploy to Staging'</span>) {
            <span class="kw-jenkins">steps</span> {
                sh <span class="str">'./deploy.sh staging'</span>
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Approval for Production'</span>) {
            <span class="kw-jenkins">when</span> { branch <span class="str">'main'</span> }
            <span class="kw-jenkins">steps</span> {
                <span class="val">input</span> message: <span class="str">'Deploy to production?'</span>, ok: <span class="str">'Deploy'</span>
            }
        }

        <span class="kw-jenkins">stage</span>(<span class="str">'Deploy to Production'</span>) {
            <span class="kw-jenkins">when</span> { branch <span class="str">'main'</span> }
            <span class="kw-jenkins">steps</span> {
                retry(3) { sh <span class="str">'./deploy.sh production'</span> }
            }
        }
    }

    <span class="kw-jenkins">post</span> {
        always  { cleanWs() }                                         <span class="cmt">// always clean workspace</span>
        success { slackSend channel: <span class="str">'#builds'</span>, message: <span class="str">'✅ Passed'</span> }
        failure { mail to: <span class="str">'team@company.com'</span>, subject: <span class="str">'❌ Build Failed'</span>,
                       body: <span class="str">"Job: ${env.JOB_NAME} — ${env.BUILD_URL}"</span> }
    }
}</div>
      </div>
    </div>

    <!-- PIPELINE BLOCKS REFERENCE -->
    <div class="section">
