<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DevOps Cheat Sheet — Git · Linux · Jenkins</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0e17;
    --surface: #111827;
    --surface2: #1a2235;
    --border: rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.14);
    --text: #e8edf5;
    --muted: #8896aa;
    --accent: #00d4ff;
    --accent2: #7c3aed;
    --green: #10b981;
    --amber: #f59e0b;
    --red: #ef4444;
    --pink: #ec4899;
    --orange: #f97316;
    --code-bg: #0d1117;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;line-height:1.6;}

  /* NAV TABS */
  .nav{
    position:sticky;top:0;z-index:100;
    background:rgba(10,14,23,0.95);
    border-bottom:1px solid var(--border2);
    backdrop-filter:blur(12px);
    display:flex;align-items:center;gap:0;padding:0 40px;
  }
  .nav-logo{font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:16px 24px 16px 0;border-right:1px solid var(--border2);margin-right:8px;}
  .nav-tab{
    padding:16px 20px;font-size:13px;font-weight:600;cursor:pointer;
    border-bottom:2px solid transparent;color:var(--muted);
    transition:all .2s;letter-spacing:0.5px;text-transform:uppercase;font-size:11px;
  }
  .nav-tab:hover{color:var(--text);}
  .nav-tab.active-git{color:#f97316;border-bottom-color:#f97316;}
  .nav-tab.active-linux{color:#10b981;border-bottom-color:#10b981;}
  .nav-tab.active-jenkins{color:#ec4899;border-bottom-color:#ec4899;}

  /* PAGES */
  .page{display:none;}
  .page.active{display:block;}

  /* Hero */
  .hero{
    padding:60px 40px 48px;
    border-bottom:1px solid var(--border);
    position:relative;overflow:hidden;
  }
  .hero-git::before{content:'';position:absolute;top:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(circle,rgba(249,115,22,0.1) 0%,transparent 70%);pointer-events:none;}
  .hero-linux::before{content:'';position:absolute;top:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(circle,rgba(16,185,129,0.09) 0%,transparent 70%);pointer-events:none;}
  .hero-jenkins::before{content:'';position:absolute;top:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(circle,rgba(236,72,153,0.09) 0%,transparent 70%);pointer-events:none;}
  .badge{
    display:inline-flex;align-items:center;gap:6px;
    font-size:11px;letter-spacing:2px;text-transform:uppercase;
    padding:4px 12px;border-radius:20px;margin-bottom:20px;
  }
  .badge-git{color:#f97316;border:1px solid rgba(249,115,22,0.35);}
  .badge-linux{color:#10b981;border:1px solid rgba(16,185,129,0.35);}
  .badge-jenkins{color:#ec4899;border:1px solid rgba(236,72,153,0.35);}
  h1{font-size:clamp(32px,5vw,52px);font-weight:800;line-height:1.1;letter-spacing:-1px;margin-bottom:12px;}
  .accent-git{color:#f97316;}
  .accent-linux{color:#10b981;}
  .accent-jenkins{color:#ec4899;}
  .subtitle{font-size:15px;color:var(--muted);max-width:560px;}
  .meta-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px;}
  .mtag{font-size:11px;padding:3px 10px;border-radius:4px;background:var(--surface2);color:var(--muted);border:1px solid var(--border2);}

  /* Layout */
  .container{max-width:1200px;margin:0 auto;padding:40px 40px;}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
  @media(max-width:900px){.grid2,.grid3{grid-template-columns:1fr;}.nav{padding:0 16px;}.container{padding:24px 16px;}.hero{padding:40px 16px 32px;}}

  /* Section headers */
  .section{margin-bottom:40px;}
  .section-title{
    font-size:11px;letter-spacing:3px;text-transform:uppercase;
    margin-bottom:16px;display:flex;align-items:center;gap:10px;
  }
  .section-title::after{content:'';flex:1;height:1px;background:var(--border2);}
  .st-git{color:#f97316;}
  .st-linux{color:#10b981;}
  .st-jenkins{color:#ec4899;}

  /* Cards */
  .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;}
  .card-title{font-size:13px;font-weight:700;letter-spacing:0.5px;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
  .dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .dot-orange{background:#f97316;}
  .dot-green{background:#10b981;}
  .dot-blue{background:#00d4ff;}
  .dot-purple{background:#7c3aed;}
  .dot-amber{background:#f59e0b;}
  .dot-red{background:#ef4444;}
  .dot-pink{background:#ec4899;}
  .dot-cyan{background:#06b6d4;}

  /* Command rows */
  .cmd-row{display:flex;align-items:baseline;gap:10px;padding:6px 0;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;}
  .cmd-row:last-child{border-bottom:none;}
  .cmd{font-size:12px;white-space:nowrap;flex-shrink:0;min-width:0;word-break:break-all;}
  .cmd-git{color:#f97316;}
  .cmd-linux{color:#10b981;}
  .cmd-jenkins{color:#ec4899;}
  .desc{font-size:12px;color:var(--muted);font-family:'Syne',sans-serif;flex:1;}

  /* Code blocks */
  .code-block{
    background:var(--code-bg);border:1px solid var(--border2);
    border-radius:8px;padding:16px;margin-top:12px;
    font-family:'JetBrains Mono',monospace;font-size:12px;
    line-height:1.8;overflow-x:auto;white-space:pre;
  }
  .cmt{color:#4a5568;}
  .kw-git{color:#f97316;}
  .kw-linux{color:#10b981;}
  .kw-jenkins{color:#ec4899;}
  .str{color:#10b981;}
  .val{color:#f59e0b;}
  .flag{color:#ec4899;}

  /* Flow diagram */
  .flow{display:flex;align-items:center;gap:0;flex-wrap:wrap;margin:12px 0;}
  .flow-step{background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:8px 14px;font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--text);white-space:nowrap;}
  .flow-arrow-git{color:#f97316;padding:0 6px;font-size:14px;}
  .flow-arrow-linux{color:#10b981;padding:0 6px;font-size:14px;}
  .flow-arrow-jenkins{color:#ec4899;padding:0 6px;font-size:14px;}

  /* Table */
  table{width:100%;border-collapse:collapse;font-size:12px;}
  th{text-align:left;padding:8px 10px;color:var(--muted);border-bottom:1px solid var(--border2);font-family:'Syne',sans-serif;font-size:11px;letter-spacing:0.5px;text-transform:uppercase;}
  td{padding:8px 10px;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;color:var(--text);}
  tr:last-child td{border-bottom:none;}
  td.note{font-family:'Syne',sans-serif;color:var(--muted);}
  tr:hover td{background:var(--surface2);}

  /* Highlight boxes */
  .tip-git{background:rgba(249,115,22,0.06);border:1px solid rgba(249,115,22,0.2);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--muted);margin-top:12px;}
  .tip-git strong{color:#f97316;}
  .tip-linux{background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.2);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--muted);margin-top:12px;}
  .tip-linux strong{color:#10b981;}
  .tip-jenkins{background:rgba(236,72,153,0.06);border:1px solid rgba(236,72,153,0.2);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--muted);margin-top:12px;}
  .tip-jenkins strong{color:#ec4899;}
  .warn{background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.2);border-radius:8px;padding:12px 14px;font-size:12px;color:var(--muted);margin-top:12px;}
  .warn strong{color:#f59e0b;}

  /* Full-width card */
  .card-full{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:16px;}

  /* Tag badges */
  .badge-must{background:rgba(16,185,129,0.12);color:#10b981;border:1px solid rgba(16,185,129,0.2);font-size:10px;padding:2px 7px;border-radius:4px;}
  .badge-mid{background:rgba(245,158,11,0.1);color:#f59e0b;border:1px solid rgba(245,158,11,0.2);font-size:10px;padding:2px 7px;border-radius:4px;}
  .badge-adv{background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.2);font-size:10px;padding:2px 7px;border-radius:4px;}

  /* check marks */
  .chk-yes{color:#10b981;}
  .chk-no{color:#ef4444;}

  .footer{text-align:center;padding:32px;border-top:1px solid var(--border);color:var(--muted);font-size:12px;}
  hr{border:none;border-top:1px solid var(--border);margin:40px 0;}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-logo">DevOps Interview Prep</div>
  <div class="nav-tab active-git" onclick="showPage('git',this)">⑁ Git</div>
  <div class="nav-tab" onclick="showPage('linux',this)">🐧 Linux</div>
  <div class="nav-tab" onclick="showPage('jenkins',this)">⚙ Jenkins</div>
</nav>

<!-- ════════════════════════════════════════════
     GIT PAGE
════════════════════════════════════════════ -->
<div id="page-git" class="page active">
  <div class="hero hero-git">
    <div class="badge badge-git">⑁ Version Control</div>
    <h1>Git <span class="accent-git">Cheat Sheet</span></h1>
    <p class="subtitle">Every Git command and concept you need to crack the DevOps interview. Built for 2–3 year experience level.</p>
    <div class="meta-tags">
      <span class="mtag">Core Workflow</span>
      <span class="mtag">Branching</span>
      <span class="mtag">Merge & Rebase</span>
      <span class="mtag">Stash & Reset</span>
      <span class="mtag">Tags & Releases</span>
      <span class="mtag">Conflict Resolution</span>
      <span class="mtag">Remote Operations</span>
      <span class="mtag">Internals</span>
    </div>
  </div>

  <div class="container">

    <!-- LIFECYCLE -->
    <div class="section">
      <div class="section-title st-git">01 — Git object model</div>
      <div class="card-full">
        <div class="card-title"><span class="dot dot-orange"></span>How Git stores everything</div>
        <div class="flow">
          <span class="flow-step">Working directory</span><span class="flow-arrow-git">→ git add →</span>
          <span class="flow-step">Staging area (Index)</span><span class="flow-arrow-git">→ git commit →</span>
          <span class="flow-step">Local repo (.git)</span><span class="flow-arrow-git">→ git push →</span>
          <span class="flow-step">Remote (GitHub)</span>
        </div>
        <div class="flow" style="margin-top:10px;">
          <span class="flow-step">Remote (GitHub)</span><span class="flow-arrow-git">→ git fetch →</span>
          <span class="flow-step">Remote tracking branch</span><span class="flow-arrow-git">→ git merge →</span>
          <span class="flow-step">Local branch</span>
        </div>
        <div class="tip-git" style="margin-top:14px;"><strong>Interview tip:</strong> <code>git pull</code> = <code>git fetch</code> + <code>git merge</code>. Always say this — it shows you understand the internals, not just the shortcut.</div>
      </div>
    </div>

    <!-- SETUP -->
    <div class="section">
      <div class="section-title st-git">02 — Setup & config</div>
      <div class="grid2">
        <div class="card">
          <div class="card-title"><span class="dot dot-orange"></span>Initial configuration</div>
          <div class="cmd-row"><span class="cmd cmd-git">git config --global user.name "Name"</span><span class="desc">Set global username</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git config --global user.email "x@y.com"</span><span class="desc">Set global email</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git config --list</span><span class="desc">View all config values</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git config --global core.editor vim</span><span class="desc">Set default editor</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git config --global alias.st status</span><span class="desc">Create command alias</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">cat ~/.gitconfig</span><span class="desc">View config file directly</span></div>
        </div>
        <div class="card">
          <div class="card-title"><span class="dot dot-green"></span>Init & clone</div>
          <div class="cmd-row"><span class="cmd cmd-git">git init</span><span class="desc">Initialize new local repo</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git clone &lt;url&gt;</span><span class="desc">Clone remote repo locally</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git clone &lt;url&gt; mydir</span><span class="desc">Clone into specific folder name</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git clone --depth 1 &lt;url&gt;</span><span class="desc">Shallow clone — latest commit only (faster)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git remote -v</span><span class="desc">Show remote URLs</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git remote add origin &lt;url&gt;</span><span class="desc">Add remote to local repo</span></div>
        </div>
      </div>
    </div>

    <!-- CORE WORKFLOW -->
    <div class="section">
      <div class="section-title st-git">03 — Core daily workflow</div>
      <div class="grid2">
        <div class="card">
          <div class="card-title"><span class="dot dot-orange"></span>Stage & commit</div>
          <div class="cmd-row"><span class="cmd cmd-git">git status</span><span class="desc">Show working tree status</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git add .</span><span class="desc">Stage all changed files</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git add &lt;file&gt;</span><span class="desc">Stage specific file</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git add -p</span><span class="desc">Interactively stage chunks (hunk by hunk)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git commit -m "message"</span><span class="desc">Commit staged changes</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git commit --amend</span><span class="desc">Edit last commit message or add files</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git commit -am "message"</span><span class="desc">Stage tracked files + commit in one step</span></div>
        </div>
        <div class="card">
          <div class="card-title"><span class="dot dot-blue"></span>Push & pull</div>
          <div class="cmd-row"><span class="cmd cmd-git">git push origin &lt;branch&gt;</span><span class="desc">Push branch to remote</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git push -u origin &lt;branch&gt;</span><span class="desc">Push and set upstream tracking</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git push --force-with-lease</span><span class="desc">Safe force push (checks for remote changes)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git pull</span><span class="desc">Fetch + merge from tracked remote branch</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git pull --rebase</span><span class="desc">Fetch + rebase instead of merge (cleaner history)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git fetch origin</span><span class="desc">Download changes without merging</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git fetch --all</span><span class="desc">Fetch from all remotes</span></div>
        </div>
      </div>
    </div>

    <!-- BRANCHING -->
    <div class="section">
      <div class="section-title st-git">04 — Branching</div>
      <div class="grid2">
        <div class="card">
          <div class="card-title"><span class="dot dot-purple"></span>Create & switch branches</div>
          <div class="cmd-row"><span class="cmd cmd-git">git branch</span><span class="desc">List all local branches</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git branch -a</span><span class="desc">List local + remote branches</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git branch &lt;name&gt;</span><span class="desc">Create new branch (stay on current)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git checkout -b &lt;name&gt;</span><span class="desc">Create and switch to branch</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git switch -c &lt;name&gt;</span><span class="desc">Modern way to create + switch (Git 2.23+)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git checkout &lt;name&gt;</span><span class="desc">Switch to existing branch</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git branch -d &lt;name&gt;</span><span class="desc">Delete local branch (safe — merged only)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git branch -D &lt;name&gt;</span><span class="desc">Force-delete local branch</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git push origin --delete &lt;name&gt;</span><span class="desc">Delete remote branch</span></div>
        </div>
        <div class="card">
          <div class="card-title"><span class="dot dot-amber"></span>Merge vs Rebase</div>
          <div class="cmd-row"><span class="cmd cmd-git">git merge &lt;branch&gt;</span><span class="desc">Merge branch — creates a merge commit</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git merge --no-ff &lt;branch&gt;</span><span class="desc">Force merge commit even on fast-forward</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git merge --squash &lt;branch&gt;</span><span class="desc">Squash all commits into one before merging</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git rebase &lt;branch&gt;</span><span class="desc">Replay commits on top — linear history</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git rebase -i HEAD~3</span><span class="desc">Interactive rebase — squash/edit/reorder last 3 commits</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git rebase --abort</span><span class="desc">Cancel an in-progress rebase</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git rebase --continue</span><span class="desc">Continue after resolving rebase conflict</span></div>
          <div class="tip-git"><strong>Golden rule:</strong> Never rebase a branch others are working on — it rewrites commit history and breaks teammates' branches.</div>
        </div>
      </div>
    </div>

    <!-- CONFLICT RESOLUTION -->
    <div class="section">
      <div class="section-title st-git">05 — Merge conflict resolution</div>
      <div class="card-full">
        <div class="card-title"><span class="dot dot-red"></span>Step-by-step conflict resolution</div>
        <div class="grid2" style="gap:20px;">
          <div>
            <div class="cmd-row"><span class="cmd cmd-git" style="min-width:200px;">1. git merge feature-branch</span><span class="desc">Start the merge — Git reports CONFLICT</span></div>
            <div class="cmd-row"><span class="cmd cmd-git" style="min-width:200px;">2. git status</span><span class="desc">See which files have conflicts</span></div>
            <div class="cmd-row"><span class="cmd cmd-git" style="min-width:200px;">3. Open conflicted file</span><span class="desc">Edit and resolve the markers manually</span></div>
            <div class="cmd-row"><span class="cmd cmd-git" style="min-width:200px;">4. git add &lt;file&gt;</span><span class="desc">Mark conflict as resolved</span></div>
            <div class="cmd-row"><span class="cmd cmd-git" style="min-width:200px;">5. git commit</span><span class="desc">Complete the merge with a commit</span></div>
            <div class="tip-git" style="margin-top:12px;"><strong>Abort instead?</strong> Run <code>git merge --abort</code> to go back to before the merge started.</div>
          </div>
          <div>
            <div style="font-size:12px;color:var(--muted);margin-bottom:8px;">Conflict markers inside the file:</div>
            <div class="code-block" style="margin-top:0;">
<span class="kw-git">&lt;&lt;&lt;&lt;&lt;&lt;&lt; HEAD</span>
your change on current branch
<span class="val">=======</span>
their change from feature-branch
<span class="kw-git">&gt;&gt;&gt;&gt;&gt;&gt;&gt; feature-branch</span>

<span class="cmt"># Delete the markers, keep the right code,</span>
<span class="cmt"># then: git add file → git commit</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- STASH RESET RECOVERY -->
    <div class="section">
      <div class="section-title st-git">06 — Stash, reset & recovery</div>
      <div class="grid2">
        <div class="card">
          <div class="card-title"><span class="dot dot-green"></span>Stash</div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash</span><span class="desc">Save uncommitted changes to stash stack</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash push -m "wip: login"</span><span class="desc">Stash with a descriptive message</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash list</span><span class="desc">List all stashed changes</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash pop</span><span class="desc">Restore latest stash + remove from stack</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash apply stash@{2}</span><span class="desc">Apply specific stash, keep it in stack</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash drop stash@{0}</span><span class="desc">Delete a stash entry</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git stash clear</span><span class="desc">Delete all stashes</span></div>
        </div>
        <div class="card">
          <div class="card-title"><span class="dot dot-red"></span>Reset & revert (most asked!)</div>
          <div class="cmd-row"><span class="cmd cmd-git">git reset --soft HEAD~1</span><span class="desc">Undo last commit — keep changes staged</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git reset --mixed HEAD~1</span><span class="desc">Undo last commit — keep changes unstaged</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git reset --hard HEAD~1</span><span class="desc">Undo last commit — discard all changes</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git revert &lt;hash&gt;</span><span class="desc">Create new commit undoing a commit (safe for shared branches)</span></div>
          <div class="cmd-row"><span class="cmd cmd-git">git checkout -- &lt;file&gt;</span><span class="desc">Discard unstaged changes in a file</span></div>
