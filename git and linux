          <div class="code-block">
<span class="kw-linux">#!/bin/bash</span>
<span class="kw-linux">set -e</span>          <span class="cmt"># exit on any error</span>
<span class="kw-linux">set -x</span>          <span class="cmt"># print each command (debug)</span>

<span class="cmt"># Variables</span>
NAME<span class="val">="devops"</span>
echo <span class="str">"Hello $NAME"</span>

<span class="cmt"># Conditionals</span>
<span class="kw-linux">if</span> [ <span class="str">"$ENV"</span> == <span class="str">"prod"</span> ]; then
  echo <span class="str">"Production!"</span>
<span class="kw-linux">elif</span> [ <span class="str">"$ENV"</span> == <span class="str">"dev"</span> ]; then
  echo <span class="str">"Dev mode"</span>
<span class="kw-linux">fi</span>

<span class="cmt"># For loop</span>
<span class="kw-linux">for</span> server in web1 web2 web3; do
  echo <span class="str">"Deploying to $server"</span>
<span class="kw-linux">done</span>

<span class="cmt"># Check exit code</span>
./deploy.sh
<span class="kw-linux">if</span> [ $? -ne 0 ]; then
