<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Docker Real-Time Project — Task Manager App</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4f1eb;
  --ink:#1a1410;
  --ink2:#5a4f44;
  --ink3:#9a8e82;
  --cream:#fffdf8;
  --rule:#d6cfc4;
  --accent:#c84b1a;
  --accent2:#2d6a4f;
  --accent3:#1a4f8a;
  --yellow:#f5c842;
  --yellow-bg:#fdf8e1;
  --green-bg:#e8f5ee;
  --blue-bg:#e8f0fa;
  --code-bg:#1a1410;
  --code-text:#e8ddd0;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--ink);font-family:'DM Sans',sans-serif;line-height:1.6;}

/* Hero */
.hero{
  background:var(--ink);color:var(--bg);
  padding:56px 48px 48px;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;right:-40px;top:-40px;
  width:280px;height:280px;
  border:40px solid rgba(255,255,255,0.04);
  border-radius:50%;
}
.hero::after{
  content:'';position:absolute;right:60px;top:40px;
  width:140px;height:140px;
  border:20px solid rgba(200,75,26,0.2);
  border-radius:50%;
}
.hero-tag{
  font-size:11px;letter-spacing:3px;text-transform:uppercase;
  color:var(--accent);font-family:'DM Mono',monospace;
  margin-bottom:18px;
}
.hero h1{
  font-family:'Fraunces',serif;font-size:clamp(36px,5vw,60px);
  font-weight:900;line-height:1.05;letter-spacing:-1px;
  margin-bottom:16px;
}
.hero h1 em{color:var(--yellow);font-style:italic;}
.hero p{font-size:15px;color:rgba(244,241,235,0.7);max-width:580px;line-height:1.7;}
.hero-stack{
  display:flex;flex-wrap:wrap;gap:8px;margin-top:24px;
}
.stack-pill{
  font-family:'DM Mono',monospace;font-size:11px;
  padding:4px 10px;border-radius:4px;
  background:rgba(255,255,255,0.08);color:var(--bg);
  border:1px solid rgba(255,255,255,0.12);
}
.stack-pill.hot{background:rgba(200,75,26,0.3);border-color:rgba(200,75,26,0.5);color:#f5c842;}

/* Nav / TOC */
.toc{
  background:var(--cream);border-bottom:1px solid var(--rule);
  padding:16px 48px;display:flex;flex-wrap:wrap;gap:6px;
  position:sticky;top:0;z-index:100;
}
.toc a{
  font-size:12px;font-family:'DM Mono',monospace;
  color:var(--ink2);text-decoration:none;
  padding:4px 10px;border-radius:4px;
  border:1px solid transparent;
  transition:all .15s;
}
.toc a:hover{background:var(--ink);color:var(--bg);border-color:var(--ink);}

/* Main layout */
.wrap{max-width:1080px;margin:0 auto;padding:48px 48px;}
@media(max-width:768px){.wrap{padding:24px 20px;}.hero,.toc{padding:32px 20px;}}

/* Section */
.section{margin-bottom:56px;}
.section-label{
  display:flex;align-items:center;gap:12px;
  font-family:'DM Mono',monospace;font-size:11px;
  letter-spacing:2px;text-transform:uppercase;
  color:var(--accent);margin-bottom:24px;
}
.section-label::after{content:'';flex:1;height:1px;background:var(--rule);}
.section-num{
  background:var(--accent);color:#fff;
  width:24px;height:24px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:500;flex-shrink:0;
}

/* Typography */
h2{font-family:'Fraunces',serif;font-size:28px;font-weight:700;margin-bottom:12px;line-height:1.2;}
h3{font-family:'Fraunces',serif;font-size:20px;font-weight:700;margin-bottom:10px;color:var(--ink);}
h4{font-size:13px;font-weight:600;letter-spacing:0.5px;margin-bottom:8px;color:var(--ink);}
p{font-size:14px;color:var(--ink2);line-height:1.75;margin-bottom:12px;}

/* Architecture diagram */
.arch{
  background:var(--cream);border:1px solid var(--rule);
  border-radius:12px;padding:28px;margin:20px 0;
}
.arch-row{
  display:flex;align-items:center;justify-content:center;
  gap:0;flex-wrap:wrap;margin:8px 0;
}
.arch-box{
  border-radius:8px;padding:10px 18px;
  font-family:'DM Mono',monospace;font-size:12px;
  font-weight:500;text-align:center;min-width:120px;
  border:1.5px solid;
}
.arch-arrow{font-size:18px;color:var(--ink3);padding:0 10px;}
.arch-label{font-size:11px;font-family:'DM Mono',monospace;color:var(--ink3);text-align:center;margin-top:4px;}
.box-blue{background:var(--blue-bg);border-color:#a8c4f0;color:var(--accent3);}
.box-green{background:var(--green-bg);border-color:#a8d4bc;color:var(--accent2);}
.box-orange{background:#fef0e8;border-color:#f0b090;color:var(--accent);}
.box-yellow{background:var(--yellow-bg);border-color:#e5d090;color:#8a6a00;}
.box-dark{background:var(--ink);border-color:var(--ink);color:var(--bg);}

/* File tree */
.filetree{
  background:var(--code-bg);border-radius:10px;
  padding:20px 24px;font-family:'DM Mono',monospace;
  font-size:13px;line-height:2;overflow-x:auto;
}
.ft-dir{color:#7ec8e3;}
.ft-file{color:var(--code-text);}
.ft-comment{color:#5a5048;}
.ft-special{color:var(--yellow);}

/* Code blocks */
.code-wrap{
  background:var(--code-bg);border-radius:10px;
  overflow:hidden;margin:12px 0;
}
.code-title{
  background:rgba(255,255,255,0.06);
  padding:8px 16px;
  font-family:'DM Mono',monospace;font-size:11px;
  color:var(--ink3);display:flex;align-items:center;
  justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.06);
}
.code-title .filename{color:var(--yellow);}
pre{
  padding:18px 20px;font-family:'DM Mono',monospace;
  font-size:12.5px;line-height:1.8;overflow-x:auto;
  color:var(--code-text);
}
.c{color:#5a7060;} /* comment */
.k{color:#7ec8e3;} /* keyword */
.s{color:#b5d99c;} /* string */
.v{color:#f5c842;} /* value/number */
.f{color:#f0a0c0;} /* flag/option */
.e{color:var(--accent);} /* emphasis */

/* Cards grid */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
@media(max-width:700px){.grid2,.grid3{grid-template-columns:1fr;}}

.card{
  background:var(--cream);border:1px solid var(--rule);
  border-radius:10px;padding:18px;
}
.card-icon{font-size:22px;margin-bottom:10px;}
.card h4{margin-bottom:6px;}
.card p{font-size:13px;margin:0;}

/* Step list */
.steps{counter-reset:step;}
.step{
  display:flex;gap:16px;margin-bottom:24px;
  padding-bottom:24px;border-bottom:1px solid var(--rule);
}
.step:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.step-num{
  background:var(--ink);color:var(--bg);
  width:32px;height:32px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Mono',monospace;font-size:13px;font-weight:500;
  flex-shrink:0;margin-top:2px;
}
.step-body{flex:1;}
.step-body h4{font-size:14px;margin-bottom:6px;}
.step-body p{font-size:13px;margin-bottom:8px;}

/* Callout boxes */
.callout{
  border-radius:8px;padding:14px 16px;
  margin:14px 0;font-size:13px;
  display:flex;gap:10px;align-items:flex-start;
}
.callout-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.callout-body{color:var(--ink2);line-height:1.65;}
.callout-body strong{color:var(--ink);}
.tip{background:var(--blue-bg);border:1px solid #c0d4f0;}
.warn{background:var(--yellow-bg);border:1px solid #e0cc80;}
.good{background:var(--green-bg);border:1px solid #a0cdb0;}

/* Interview badges */
.interview-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(200,75,26,0.1);border:1px solid rgba(200,75,26,0.25);
  color:var(--accent);font-size:11px;font-family:'DM Mono',monospace;
  padding:3px 10px;border-radius:20px;margin-left:8px;
}

/* Command table */
table{width:100%;border-collapse:collapse;font-size:13px;margin:10px 0;}
th{text-align:left;padding:9px 12px;font-size:11px;letter-spacing:0.5px;
  text-transform:uppercase;color:var(--ink2);
  border-bottom:2px solid var(--rule);font-family:'DM Mono',monospace;}
td{padding:9px 12px;border-bottom:1px solid var(--rule);}
td:first-child{font-family:'DM Mono',monospace;font-size:12px;color:var(--accent3);}
td.note{color:var(--ink2);}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(0,0,0,0.02);}

/* Footer */
footer{
  background:var(--ink);color:var(--bg);
  text-align:center;padding:32px;
  font-size:13px;color:rgba(244,241,235,0.5);
}
footer strong{color:var(--yellow);}
</style>
</head>
