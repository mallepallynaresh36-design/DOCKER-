  <!-- 11. CI/CD -->
  <div class="section" id="cicd">
    <div class="section-label"><span class="section-num">11</span>Jenkins CI/CD pipeline</div>
    <h2>Jenkinsfile — full pipeline</h2>
    <div class="code-wrap">
      <div class="code-title"><span class="filename">Jenkinsfile</span><span>Declarative pipeline</span></div>
      <pre><span class="k">pipeline</span> {
  <span class="k">agent</span> any

  <span class="k">environment</span> {
    IMAGE_NAME  = <span class="s">"taskmanager"</span>
    REGISTRY    = <span class="s">"your-registry.io"</span>
    GIT_COMMIT  = sh(returnStdout: true, script: <span class="s">'git rev-parse --short HEAD'</span>).trim()
  }

  <span class="k">stages</span> {
    <span class="k">stage</span>(<span class="s">'Checkout'</span>) {
      steps { checkout scm }
    }

    <span class="k">stage</span>(<span class="s">'Build Images'</span>) {
      <span class="k">parallel</span> {
        <span class="k">stage</span>(<span class="s">'Build Backend'</span>) {
          steps {
            sh <span class="s">'docker build -t $REGISTRY/$IMAGE_NAME-backend:$GIT_COMMIT ./backend'</span>
          }
        }
        <span class="k">stage</span>(<span class="s">'Build Frontend'</span>) {
          steps {
            sh <span class="s">'docker build -t $REGISTRY/$IMAGE_NAME-frontend:$GIT_COMMIT ./frontend'</span>
          }
        }
      }
    }

    <span class="k">stage</span>(<span class="s">'Test'</span>) {
      steps {
        sh <span class="s">'''
          docker run --rm \
            -e NODE_ENV=test \
            $REGISTRY/$IMAGE_NAME-backend:$GIT_COMMIT \
            npm test
        '''</span>
      }
    }

    <span class="k">stage</span>(<span class="s">'Security Scan'</span>) {
      steps {
        sh <span class="s">'docker scout cves $REGISTRY/$IMAGE_NAME-backend:$GIT_COMMIT'</span>
      }
    }

    <span class="k">stage</span>(<span class="s">'Push to Registry'</span>) {
      steps {
        <span class="k">withDockerRegistry</span>([credentialsId: <span class="s">'registry-creds'</span>]) {
          sh <span class="s">'docker push $REGISTRY/$IMAGE_NAME-backend:$GIT_COMMIT'</span>
          sh <span class="s">'docker push $REGISTRY/$IMAGE_NAME-frontend:$GIT_COMMIT'</span>
          <span class="c">// Also tag as latest</span>
          sh <span class="s">'docker tag $REGISTRY/$IMAGE_NAME-backend:$GIT_COMMIT $REGISTRY/$IMAGE_NAME-backend:latest'</span>
          sh <span class="s">'docker push $REGISTRY/$IMAGE_NAME-backend:latest'</span>
        }
      }
    }

    <span class="k">stage</span>(<span class="s">'Deploy'</span>) {
      when { branch <span class="s">'main'</span> }
      steps {
        sh <span class="s">'docker compose -f docker-compose.prod.yml pull'</span>
        sh <span class="s">'docker compose -f docker-compose.prod.yml up -d --no-deps'</span>
      }
    }
  }

  <span class="k">post</span> {
    always {
      sh <span class="s">'docker image prune -f'</span>  <span class="c">// cleanup</span>
    }
    failure {
      echo <span class="s">'Pipeline failed — notify team'</span>
    }
  }
}</pre>
    </div>
  </div>

